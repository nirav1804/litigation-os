# ════════════════════════════════════════════════════════════════
# Litigation OS — Environment Configuration
# Copy to .env and fill in all REQUIRED values
# ════════════════════════════════════════════════════════════════

# ─── SECURITY (REQUIRED) ─────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_min_32_chars

# ─── AI — GROQ (REQUIRED) ────────────────────────────────────────
# Free key at: https://console.groq.com
GROQ_API_KEY=gsk_CHANGE_ME

# ─── DATABASE ────────────────────────────────────────────────────
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password

# ─── FILE STORAGE (MinIO defaults — works out of the box) ────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_minio_password
S3_BUCKET=litigation-os
AWS_REGION=ap-south-1

# ─── URLS ────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
JWT_EXPIRES_IN=15m

# ─── EMAIL (OPTIONAL — logs to console if not set) ───────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=Litigation OS <noreply@litigationos.in>
