# ─── APPLICATION ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# ─── DATABASE (REQUIRED) ──────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/litigation_os?schema=public&connection_limit=10&pool_timeout=20"

# ─── SECURITY (REQUIRED) ──────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_at_least_32_characters_long
JWT_EXPIRES_IN=15m

# ─── AI — GROQ (REQUIRED) ─────────────────────────────────────────────────────
# Get free key at: https://console.groq.com
# Models: llama-3.3-70b-versatile, llama-3.1-8b-instant, mixtral-8x7b-32768
GROQ_API_KEY=gsk_CHANGE_ME_your_groq_key

# ─── FILE STORAGE (REQUIRED) ──────────────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin123
S3_BUCKET=litigation-os
# For MinIO (local dev):
S3_ENDPOINT=http://localhost:9000
# For real AWS S3: remove S3_ENDPOINT line above

# ─── EMAIL (OPTIONAL) ─────────────────────────────────────────────────────────
# App works without this — emails are logged to console
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=Litigation OS <noreply@litigationos.in>
